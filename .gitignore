# Root .gitignore for full monorepo

# Node / React
node_modules/
build/
dist/
.DS_Store
.env
.env.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Frontend-specific
/Frontend/node_modules/
/Frontend/build/
/Frontend/dist/
/Frontend/.env*

# Python / Backend
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
venv/
env/
.venv/
Backend/venv/
Backend/env/
Backend/.venv/
*.egg-info/
pip-wheel-metadata/
*.egg
*.sqlite3
*.log
.pytest_cache/
.mypy_cache/

# IDEs and editors
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Optional: generated local files
*.local
